{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api-gateway/Dockerfile"
  },
  "deploy": {
    "startCommand": "node apps/api-gateway/dist/main",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 100
  }
}
